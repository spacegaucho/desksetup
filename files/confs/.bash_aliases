#!/bin/bash
alias apt-get='sudo apt-get'
alias gitchecker='bash ~/scripts/sh/gitchecker.sh'
alias g-scripts="cd ~/git/scripts/"
alias g-tmp="cd ~/tmp/"
alias k="kubectl"
alias kcx="kubectl-ctx"
alias kns="kubectl-ns"
alias l='ls -hCF'
alias la='ls -hA'
alias ll='ls -ahlF'
alias lls='ls -ahlFSr'
alias llt='ls -ahlFtr'
alias p='ping'
alias s="ssh"
alias sk="~/git/scripts/sh/sshlogin-keytransfer.sh"
alias ssh_clean_offending="~/scripts/sh/ssh_remove_offending_ip_key.sh"
alias tf="terraform"
alias venv_ansible='. ~/virtualenv/ansible/bin/activate'
alias vi='nvim'
alias vim='nvim'
alias vps="~/scripts/sh/vpnpsitadmin.sh"
alias vy='nvim -c "set syntax=yaml"'
alias xw='~/scripts/sh/xw.sh'
